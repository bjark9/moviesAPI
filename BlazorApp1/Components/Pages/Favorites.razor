@page "/favorites"
@inject FavoritesState FavoritesState
@inject UserService UserService
@implements IDisposable

@if (UserService.CurrentUser == null)
{
    <p>You must <a href="/login">log in</a> to view your favorites.</p>
}
else
{
    <h3>@UserService.CurrentUser.Username's Favorites</h3>
    <ul>
        @foreach (var movie in FavoritesState.Favorites)
        {
            <li>@movie.Title</li>
            <button @onclick="() => HandleRemoveFromFavorites(movie)">Remove from Favorites</button>
        }
    </ul>
}

@code {
    protected override void OnInitialized()
    {
        FavoritesState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        FavoritesState.OnChange -= StateHasChanged;
    }

    public void HandleRemoveFromFavorites(Movie movie)
    {
        FavoritesState.RemoveFromFavorites(movie);
    }

}