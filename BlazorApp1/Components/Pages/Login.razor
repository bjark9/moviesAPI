@page "/login"
@inject UserService UserService
@inject NavigationManager NavigationManager

<h2>Login</h2>
<label for="username">Username:</label>
<input type="text" id="username" @bind="username" />

<label for="pwd">Password:</label>
<input type="password" id="pwd" @bind="password" />

<label for="submit">Submit</label>
<input type="submit" @onclick="HandleAuthentification" />

@if (!string.IsNullOrEmpty(message))
{
    <p>@message</p>
}

@code{
    public string? password;
    public string? username;
    private string? message;

    public void HandleAuthentification()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            message = "Please enter both username and password.";
            return;
        }

        bool success = UserService.Login(username!, password!);
        if (success)
        {
            message = "Login successful.";
            NavigationManager.NavigateTo("/favorites");
        }
        else
        {
            message = "Invalid credentials.";
        }
    }
}